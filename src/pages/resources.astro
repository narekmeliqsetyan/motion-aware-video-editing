---
import BaseLayout from '../layouts/BaseLayout.astro';
import PDFViewer from '../components/PDFViewer.astro';
import { url } from '../utils/url';
---

<BaseLayout title="Resources">
  <h1>Resources</h1>
  <p class="page-intro">
    Research papers, thesis review documents, and supplementary materials.
  </p>

  <section class="section">
    <h2 class="section-title">IST Paper</h2>
    <PDFViewer
      src={url('/assets/papers/IST_paper.pdf')}
      title="IST Paper"
    />
  </section>

  <section class="section">
    <h2 class="section-title">Jupyter Notebooks</h2>
    <div class="grid-2">
      <div class="card">
        <h3>Motion-Aware Object Replacement</h3>
        <p class="notebook-desc">Main pipeline notebook with end-to-end object replacement.</p>
        <a href={url('/assets/notebooks/motion_aware_object_replacement.ipynb')} download class="btn">Download .ipynb</a>
      </div>
      <div class="card">
        <h3>SAM2 vs YOLOv8 Experiments</h3>
        <p class="notebook-desc">Mask propagation comparison experiments and metrics.</p>
        <a href={url('/assets/notebooks/review_frames_sam2_yolov8_experiments.ipynb')} download class="btn">Download .ipynb</a>
      </div>
      <div class="card">
        <h3>GAN Video Replace</h3>
        <p class="notebook-desc">GAN-based video object replacement approach.</p>
        <a href={url('/assets/notebooks/gan-video-replace-adjusted.ipynb')} download class="btn">Download .ipynb</a>
      </div>
      <div class="card">
        <h3>Video Preprocessing for Inpainting</h3>
        <p class="notebook-desc">Frame extraction, mask preparation, and preprocessing steps.</p>
        <a href={url('/assets/notebooks/video-preprocessing-for-inpainting.ipynb')} download class="btn">Download .ipynb</a>
      </div>
      <div class="card">
        <h3>Video Replace All-in-One</h3>
        <p class="notebook-desc">Combined pipeline running all steps sequentially.</p>
        <a href={url('/assets/notebooks/video_replace_all_in_one.ipynb')} download class="btn">Download .ipynb</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Additional Resources</h2>
    <div class="grid-2">
      <div class="card">
        <h3>Key References</h3>
        <ul>
          <li><a href="https://github.com/facebookresearch/sam2" target="_blank" rel="noopener">SAM2 — Segment Anything Model 2</a></li>
          <li><a href="https://github.com/sczhou/ProPainter" target="_blank" rel="noopener">ProPainter — Video Inpainting</a></li>
          <li><a href="https://arxiv.org/abs/2301.07093" target="_blank" rel="noopener">Stable Diffusion Inpainting</a></li>
        </ul>
      </div>
      <div class="card">
        <h3>Datasets</h3>
        <ul>
          <li><a href="https://davischallenge.org/" target="_blank" rel="noopener">DAVIS — Video Object Segmentation</a></li>
          <li><a href="https://youtube-vos.org/" target="_blank" rel="noopener">YouTube-VOS</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro {
    font-size: 1.1rem;
    color: var(--c-text-muted);
    margin-bottom: var(--space-2xl);
  }
  ul {
    padding-left: var(--space-xl);
    margin-top: var(--space-sm);
  }
  li {
    margin-bottom: var(--space-xs);
  }
  .notebook-desc {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    margin-bottom: var(--space-md);
  }
</style>
