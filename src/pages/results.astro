---
import BaseLayout from '../layouts/BaseLayout.astro';
import LineChart from '../components/LineChart.astro';
import MetricsTable from '../components/MetricsTable.astro';
import { url } from '../utils/url';

const csvUrl = url('/assets/data/mask_metrics_sam2_vs_yolo.csv');
const ninjaCsvUrl = url('/assets/data/ninjas.csv');
---

<BaseLayout title="Results">
  <h1>Results</h1>
  <p class="page-intro">
    Quantitative evaluation of our motion-aware video editing pipeline
    comparing SAM2 and YOLO-based mask propagation strategies.
  </p>

  <section class="section">
    <h2 class="section-title">Mask Quality Metrics</h2>
    <div class="charts-grid">
      <LineChart
        csvUrl={csvUrl}
        xColumn="frame_idx"
        yColumns={['iou']}
        labels={['IoU (SAM2 vs YOLO)']}
        title="IoU vs Frame Index"
        yLabel="IoU"
      />
      <LineChart
        csvUrl={csvUrl}
        xColumn="frame_idx"
        yColumns={['dice']}
        labels={['Dice Coefficient']}
        title="Dice Coefficient vs Frame Index"
        yLabel="Dice"
      />
      <LineChart
        csvUrl={csvUrl}
        xColumn="frame_idx"
        yColumns={['ssim']}
        labels={['SSIM']}
        title="SSIM vs Frame Index"
        yLabel="SSIM"
      />
      <LineChart
        csvUrl={csvUrl}
        xColumn="frame_idx"
        yColumns={['area_sam2', 'area_yolo']}
        labels={['SAM2 Mask Area', 'YOLO Mask Area']}
        title="Mask Area Comparison"
        yLabel="Area (pixels)"
      />
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Video Gallery</h2>

    <div class="featured-video card video-card">
      <div class="video-badge">Featured</div>
      <h3>Mask Comparison: YOLO vs SAM2</h3>
      <p class="video-desc">Side-by-side comparison of YOLO and SAM2 mask propagation on the same video clip, highlighting differences in mask quality and temporal stability.</p>
      <video controls preload="metadata">
        <source src={url('/assets/videos/mask_compare_yolo_vs_sam2.mp4')} type="video/mp4" />
      </video>
    </div>

    <div class="video-grid">
      <div class="card video-card">
        <h3>Object Replacement: Cat to Drone</h3>
        <p class="video-desc">Replacing a walking cat with a drone using the full pipeline.</p>
        <video controls preload="metadata">
          <source src={url('/assets/videos/output_replace_cat_to_drone.mp4')} type="video/mp4" />
        </video>
      </div>
      <div class="card video-card">
        <h3>Final Result</h3>
        <p class="video-desc">End-to-end pipeline output with motion-aware warping and compositing.</p>
        <video controls preload="metadata">
          <source src={url('/assets/videos/result.mp4')} type="video/mp4" />
        </video>
      </div>
      <div class="card video-card">
        <h3>Bear Clip Baseline</h3>
        <p class="video-desc">Baseline clip used for segmentation and inpainting evaluation.</p>
        <video controls preload="metadata">
          <source src={url('/assets/videos/bear_clip_baseline.mp4')} type="video/mp4" />
        </video>
      </div>
      <div class="card video-card">
        <h3>Humans Video Preview</h3>
        <p class="video-desc">Non-rigid motion test case with articulated human subjects.</p>
        <video controls preload="metadata">
          <source src={url('/assets/videos/humans_vid3_preview.mp4')} type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Key Findings</h2>
    <div class="grid-2">
      <div class="card stat-card">
        <div class="stat-value">0.91</div>
        <div class="stat-label">Mean IoU</div>
        <p>SAM2 vs YOLO mask overlap across 60 frames</p>
      </div>
      <div class="card stat-card">
        <div class="stat-value">0.95</div>
        <div class="stat-label">Mean Dice</div>
        <p>High mask agreement between methods</p>
      </div>
      <div class="card stat-card">
        <div class="stat-value">0.98</div>
        <div class="stat-label">Mean SSIM</div>
        <p>Near-perfect structural similarity in masked regions</p>
      </div>
      <div class="card stat-card">
        <div class="stat-value">~15K</div>
        <div class="stat-label">Avg Mask Area</div>
        <p>SAM2 produces slightly tighter masks than YOLO</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Object Insertion Parameters</h2>
    <MetricsTable csvUrl={ninjaCsvUrl} title="Per-Frame Insertion Parameters (ninjas.csv)" />
  </section>
</BaseLayout>

<style>
  .page-intro {
    font-size: 1.1rem;
    color: var(--c-text-muted);
    margin-bottom: var(--space-2xl);
  }
  .charts-grid {
    display: grid;
    gap: var(--space-lg);
  }
  @media (min-width: 1024px) {
    .charts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  /* Featured video — full width */
  .featured-video {
    position: relative;
    margin-bottom: var(--space-lg);
  }
  .video-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    background: var(--c-primary);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    z-index: 1;
  }
  .featured-video video {
    width: 100%;
    border-radius: var(--radius-md);
    margin-top: var(--space-sm);
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: #000;
  }

  /* Video grid — 2 columns */
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .video-card {
    display: flex;
    flex-direction: column;
  }
  .video-card video {
    width: 100%;
    border-radius: var(--radius-md);
    margin-top: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: #000;
  }
  .video-card h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }
  .video-desc {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-sm);
  }
  .stat-card {
    text-align: center;
  }
  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--c-primary);
  }
  .stat-label {
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .stat-card p {
    font-size: 0.85rem;
    color: var(--c-text-muted);
  }
</style>
