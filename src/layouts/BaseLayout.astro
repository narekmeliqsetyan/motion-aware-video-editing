---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  math?: boolean;
}

const { title, description = 'Motion-Aware Video Editing: AI-powered object replacement using generative models', math = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Motion-Aware Video Editing</title>
    {math && (
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    )}
    <!-- Theme: inline script to prevent FOUC -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const preferred = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', preferred);
      })();
    </script>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    {math && (
      <script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    )}
    {math && (
      <script is:inline>
        function loadAutoRender() {
          var s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js';
          s.onload = function() {
            renderMathInElement(document.body, {
              delimiters: [
                {left: '$$', right: '$$', display: true},
                {left: '$', right: '$', display: false}
              ]
            });
          };
          document.body.appendChild(s);
        }
        if (window.katex) loadAutoRender();
        else document.querySelector('script[src*="katex.min.js"]').onload = loadAutoRender;
      </script>
    )}
  </body>
</html>
