---
interface Props {
  src: string;
  title: string;
}

const { src, title } = Astro.props;
---

<div class="pdf-viewer">
  <div class="pdf-header">
    <h3>{title}</h3>
    <div class="pdf-actions">
      <a href={src} target="_blank" rel="noopener" class="btn">Open in new tab</a>
      <a href={src} download class="btn btn-primary">Download PDF</a>
    </div>
  </div>
  <div class="pdf-embed">
    <iframe src={src} title={title} loading="lazy"></iframe>
  </div>
</div>

<style>
  .pdf-viewer {
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--c-bg-alt);
  }
  .pdf-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding: var(--space-md);
    border-bottom: 1px solid var(--c-border);
  }
  .pdf-actions {
    display: flex;
    gap: var(--space-sm);
  }
  .pdf-embed {
    height: 600px;
  }
  iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 640px) {
    .pdf-embed { display: none; }
    .pdf-header { flex-direction: column; align-items: flex-start; }
  }
</style>
