---
interface Props {
  title: string;
  message?: string;
}

const { title, message = 'This content will be available when the required assets are added.' } = Astro.props;
---

<div class="placeholder-card">
  <div class="placeholder-icon">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <path d="m21 15-5-5L5 21"/>
    </svg>
  </div>
  <h4>{title}</h4>
  <p>{message}</p>
</div>

<style>
  .placeholder-card {
    background: var(--c-surface);
    border: 2px dashed var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    text-align: center;
    color: var(--c-text-muted);
  }
  .placeholder-icon {
    margin-bottom: var(--space-md);
    opacity: 0.5;
  }
  h4 { margin-bottom: var(--space-sm); color: var(--c-text); }
  p { font-size: 0.875rem; }
</style>
